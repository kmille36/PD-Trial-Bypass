#!/bin/bash

clear

echo "© 2026 fb.com/thuong.hai.581."
echo "All rights reserved."

if [ "$EUID" -eq 0 ]; then
  echo "Do NOT run this script as root. Run normally."
  exit 1
fi

if ! ls /Applications | grep -qi "Parallels Desktop"; then
  echo "Parallels not installed. Exiting..."
  exit 1
fi

echo "Parallels detected. Continuing..."

echo "Please type your MacOS password!"
sudo -v

cleanup() {
  echo ""
  echo "CTRL+C detected. Cleaning up..."

  echo "Please type your MacOS password AGAIN!"
  sudo -v
  
  killall "Parallels Desktop" 2>/dev/null
  sudo killall prl_client_app 2>/dev/null
  sudo killall prl_vm_app 2>/dev/null

  echo "Restoring network time..."
  sudo systemsetup -setusingnetworktime on >/dev/null 2>&1
  sudo sntp -sS time.apple.com >/dev/null 2>&1

  echo "Done. Exiting."
  exit 0
}

trap cleanup INT


# Check if any Parallels processes are running
if pgrep -f "Parallels Desktop" >/dev/null || \
   pgrep -f prl_client_app >/dev/null || \
   pgrep -f prl_vm_app >/dev/null; then

  read -p "Parallels detected. FORCE kill processes? (y/n): " answer

  case "$answer" in
    y|Y)
      echo "Killing Parallels..."
      sudo killall "Parallels Desktop" prl_client_app prl_vm_app 2>/dev/null
      ;;
    n|N)
      echo "Exit."
      exit 0
      ;;
    *)
      echo "Invalid input."
      exit 1
      ;;
  esac

else
  echo "No Parallels processes running."
fi

echo "Disabling network time..."
sudo systemsetup -setusingnetworktime off >/dev/null 2>&1

# Correct user plist path (root)
PLIST="/var/root/Library/Preferences/com.parallels.desktop.plist"

echo "Extracting started_at..."

STARTED_AT=$(sudo plutil -p $PLIST | tr ',' '\n' | grep '"started_at"' | head -1 | sed 's/.*"\(202[0-9-]*\)".*/\1/' | tr -d '-')

echo "Raw extracted date: $STARTED_AT"

if [[ -z "$STARTED_AT" ]]; then
  echo "ERROR: Could not extract started_at"
  exit 1
fi

# Convert YYYYMMDD → macOS format MMDD0000YYYY
MM=${STARTED_AT:4:2}
DD=${STARTED_AT:6:2}
YYYY=${STARTED_AT:0:4}

MAC_DATE="${MM}${DD}0000${YYYY}"

echo "Setting system date to $MAC_DATE ..."
sudo date "$MAC_DATE"

echo "Starting Parallels Desktop..."

open -a "Parallels Desktop" --args

echo "Waiting for UI to START!"
sleep 5

# Get first VM name (you can change selection logic if needed)
VM=$(prlctl list -a -o name | tail -n +2 | head -n 1)

if [ -z "$VM" ]; then
  echo "No VM found"
  exit 1
fi

echo "Selected VM: $VM"

# Disable time sync
prlctl set "$VM" --time-sync off

# Start VM
prlctl start "$VM"

echo "VM started: $VM"

echo "Waiting for Parallels to close (Press Ctrl + C to FORCE)..."

while true; do
  if ! pgrep -f "Parallels Desktop" >/dev/null \
    && ! pgrep -f prl_client_app >/dev/null \
    && ! pgrep -f prl_vm_app >/dev/null; then

    echo "Parallels not running. Restoring network time..."

    echo "Please type your MacOS password AGAIN!"
    sudo -v

    sudo systemsetup -setusingnetworktime on >/dev/null 2>&1
    sudo sntp -sS time.apple.com >/dev/null 2>&1

    echo "Done."
    exit 0
  fi

  sleep 15
done
